{
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@libsql/client": "^0.17.4",
    "@shopify/app-bridge-react": "^4.2.11",
    "@shopify/shopify-api": "^13.1.0",
    "@tabler/icons-react": "^3.44.0",
    "@xyflow/react": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crisp-sdk-web": "^1.2.0",
    "drizzle-orm": "^0.45.2",
    "next": "16.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@happy-dom/global-registrator": "^20.10.6",
    "@shopify/app-bridge-types": "^0.7.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "ultracite": "7.8.3"
  },
  "name": "presswall",
  "scripts": {
    "dev": "next dev --turbopack -p ${PORT:-3001}",
    "dev:shopify": "bash scripts/shopify-app-dev.sh",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "shopify:deploy:prod": "shopify app deploy -c prod --allow-updates && bash scripts/shopify-dev-clean-store.sh",
    "shopify:restore-urls": "shopify app deploy -c prod --allow-updates --message \"Restore production app URLs to presswall.noxify.io\" && bash scripts/shopify-dev-clean-store.sh",
    "shopify:dev-clean": "bash scripts/shopify-dev-clean-store.sh",
    "shopify:end-dev": "bun run shopify:dev-clean && bun run shopify:restore-urls",
    "check:shopify-urls": "bash scripts/assert-shopify-url-safety.sh",
    "deploy:aws": "bash scripts/deploy-aws-apprunner.sh",
    "deploy:aws:ecs": "bash scripts/deploy-aws-ecs.sh",
    "deploy:aws:vps": "bash scripts/deploy-aws-ec2-debian.sh",
    "deploy:aws:update": "bash scripts/update-vps-container.sh",
    "lint": "ultracite check",
    "format": "ultracite fix",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "bun run db:apply-pending && drizzle-kit push",
    "db:apply-pending": "bun --env-file=.env.local scripts/apply-pending-migrations.ts && bun --env-file=.env.local scripts/migrate-legacy-custom-logos.ts",
    "db:reset-onboarding": "bun --env-file=.env.local scripts/reset-shop-onboarding.ts",
    "db:studio": "drizzle-kit studio"
  },
  "type": "module",
  "version": "0.0.1",
  "private": true
}
