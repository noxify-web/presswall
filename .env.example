SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=write_app_proxy,read_themes

# Stable dev tunnel (ngrok). Must match shopify.app.toml application_url.
SHOPIFY_APP_URL=https://reissue-irritable-slider.ngrok-free.dev

# Turso (production + remote dev)
TURSO_DATABASE_URL=libsql://your-database-name-org.turso.io
TURSO_AUTH_TOKEN=

# Local fallback when TURSO_* is unset: file:data/dev.db

# Free Crisp.chat live support (admin app only). Website ID from
# Crisp Dashboard → Settings → Workspace Settings → Setup & Integrations.
# Leave unset to disable the chatbox (app still works).
# NEXT_PUBLIC_CRISP_WEBSITE_ID=

# Production deploy only (see .env.production.example, AGENTS.md)
# VPS_IP=35.169.154.151