SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=write_app_proxy,read_themes

# Set automatically by `shopify app dev` — do not hardcode localhost during dev
# SHOPIFY_APP_URL=

# Turso (production + remote dev)
TURSO_DATABASE_URL=libsql://your-database-name-org.turso.io
TURSO_AUTH_TOKEN=

# Local fallback when TURSO_* is unset: file:data/dev.db